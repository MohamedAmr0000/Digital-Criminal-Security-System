<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Digital Evidence Locker</title>

<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700&family=Rajdhani:wght@400;500;700&display=swap" rel="stylesheet">

<style>

/* ========== RESET ========== */
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

:root{
    --main-color:#ff003c;
}

body{
    width:100%;
    height:100vh;
    overflow:hidden;
    background:#050505;
    font-family:'Rajdhani',sans-serif;
    color:white;
}

/* GRID BACKGROUND */
body::before{
    content:"";
    position:absolute;
    inset:0;
    background:
    linear-gradient(rgba(255,0,60,.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,0,60,.05) 1px, transparent 1px);
    background-size:40px 40px;
    z-index:0;
}

/* MAIN CONTAINER */
.container{
    width:100%;
    height:100vh;
    display:flex;
    position:relative;
    z-index:2;
}

/* LEFT SIDE */
.left{
    width:50%;
    height:100%;
    position:relative;
    overflow:hidden;
    border-right:1px solid rgba(255,0,60,.15);
}

.left img{
    width:100%;
    height:100%;
    object-fit:cover;
    filter:grayscale(100%) contrast(115%) brightness(.78);
}

.overlay{
    position:absolute;
    inset:0;
    background:linear-gradient(to bottom, rgba(0,0,0,.45), rgba(120,0,0,.25));
}

.scan-line{
    position:absolute;
    left:0;
    width:100%;
    height:4px;
    background:var(--main-color);
    box-shadow:0 0 20px var(--main-color);
    animation:scan 4s linear infinite;
}

@keyframes scan{
    0%{top:0%}
    100%{top:100%}
}

/* PROFILE */
.profile-title{
    position:absolute;
    top:40px;
    left:40px;
    z-index:10;
}

.profile-title h1{
    font-size:42px;
    font-family:'Orbitron',sans-serif;
    color:var(--main-color);
    text-shadow:0 0 20px rgba(255,0,60,.6);
}

.profile-title span{
    font-size:16px;
    color:#ddd;
}

/* INFO */
.subject-info{
    position:absolute;
    bottom:50px;
    left:40px;
}

.subject-info h2{
    color:var(--main-color);
    margin-bottom:15px;
}

.subject-info p{
    margin:6px 0;
    color:#ddd;
}

/* RIGHT SIDE */
.right{
    width:50%;
    height:100%;
    display:flex;
    justify-content:center;
    align-items:center;
    position:relative;
}

/* CLOCK */
.top-bar{
    position:absolute;
    top:20px;
    left:30px;
    color:#aaa;
    font-family:Consolas;
}

/* STATUS */
.status{
    position:absolute;
    top:20px;
    right:30px;
    color:var(--main-color);
    font-family:Consolas;
}

/* LOGIN BOX */
.login-box{
    width:430px;
    padding:45px;
    background:rgba(0,0,0,.45);
    border:1px solid rgba(255,0,60,.35);
    backdrop-filter:blur(12px);
    border-radius:20px;
}

/* TITLE */
.login-box h1{
    color:var(--main-color);
    font-family:'Orbitron';
    margin-bottom:10px;
}

/* FORM */
.input-group{
    margin-bottom:20px;
}

.input-group label{
    display:block;
    margin-bottom:8px;
    color:#aaa;
}

.input-group input{
    width:100%;
    height:55px;
    padding:10px;
    border:none;
    outline:none;
    border-radius:10px;
    background:#0a0a0a;
    color:white;
    border:1px solid rgba(255,0,60,.25);
}

/* BUTTON */
.login-btn{
    width:100%;
    height:55px;
    border:none;
    cursor:pointer;
    background:var(--main-color);
    color:white;
    font-size:18px;
    border-radius:12px;
    font-family:'Orbitron';
}

.login-btn:hover{
    box-shadow:0 0 25px var(--main-color);
}

/* WARNING */
.warning{
    margin-top:20px;
    font-size:12px;
    color:#777;
    text-align:center;
}

</style>
</head>

<body>

<div class="container">

    <!-- LEFT -->
    <div class="left">

        <img id="user-img">

        <div class="overlay"></div>
        <div class="scan-line"></div>

        <div class="profile-title">
            <h1 id="role-title">PROFILE</h1>
            <span id="role-job">USER ACCESS</span>
        </div>

        <div class="subject-info">
            <h2>SUBJECT ANALYSIS</h2>
            <p>STATUS : VERIFIED</p>
            <p>SECURITY LEVEL : HIGH</p>
        </div>

    </div>

    <!-- RIGHT -->
    <div class="right">

        <div class="top-bar" id="clock"></div>

        <div class="status">
            SYSTEM : SECURE<br>
            FIREWALL : ACTIVE
        </div>

        <div class="login-box">

            <h1>LOGIN ACCESS</h1>

            <!-- 🔥 IMPORTANT: THIS IS CONNECTED TO SERVLET -->
            <form action="LoginServlet" method="post">

                <div class="input-group">

                    <label>USERNAME</label>

                    <input type="text" name="username"
                    placeholder="Enter Username">

                </div>

                <div class="input-group">

                    <label>PASSWORD</label>

                    <input type="password" name="password"
                    placeholder="Enter Password">

                </div>

                <button class="login-btn" type="submit">

                    AUTHENTICATE

                </button>

            </form>

            <div class="warning">
                UNAUTHORIZED ACCESS WILL BE LOGGED
            </div>

        </div>

    </div>

</div>

<script>

/* CLOCK */
function updateClock(){

    const now = new Date();
    document.getElementById("clock").innerHTML =
    now.toLocaleDateString() + "<br>" +
    now.toLocaleTimeString();

}

setInterval(updateClock,1000);
updateClock();

/* GET USER IMAGE FROM URL */
const params = new URLSearchParams(window.location.search);
const userImage = params.get("user");

if(userImage){
    document.getElementById("user-img").src = "image/" + userImage;
}

/* ROLE DETECTION */
if(userImage === "me.jpg"){
    document.getElementById("role-title").innerText = "TEAM LEADER";
    document.getElementById("role-job").innerText = "FULL STACK DEVELOPER";
}

else if(userImage === "Basma.jpg"){
    document.getElementById("role-title").innerText = "SYSTEM ADMIN";
    document.getElementById("role-job").innerText = "HARDWARE ADMIN";
}

else if(userImage === "habiba.jpg"){
    document.getElementById("role-title").innerText = "DATABASE ADMIN";
    document.getElementById("role-job").innerText = "DB DESIGNER";
}

else if(userImage === "MoamedGmal.jpg"){
    document.getElementById("role-title").innerText = "BACKEND DEV";
    document.getElementById("role-job").innerText = "JAVA ENGINEER";
}

else if(userImage === "malak.jpg"){
    document.getElementById("role-title").innerText = "FRONTEND DEV";
    document.getElementById("role-job").innerText = "UI ENGINEER";
}

</script>

</body>
</html>