<%@page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>BLACK CODE | الجيل القادم - نظام التحقيق الجنائي</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;800&family=Orbitron:wght@500;600;700;800;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Cairo', sans-serif;
            background: #05070a;
            position: relative;
            overflow: hidden;
        }

        /* خلفية متحركة ثلاثية الأبعاد */
        .cyber-bg {
            position: fixed;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at 30% 40%, #0a0f1f, #020408);
            z-index: 0;
        }

        .cyber-bg::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: repeating-linear-gradient(
                45deg,
                transparent 0px,
                transparent 40px,
                rgba(0, 242, 255, 0.02) 40px,
                rgba(0, 242, 255, 0.02) 80px
            );
            animation: drift 30s linear infinite;
        }

        @keyframes drift {
            0% { transform: translate(0, 0); }
            100% { transform: translate(80px, 80px); }
        }

        /* جسيمات متوهجة */
        .particles {
            position: fixed;
            width: 100%;
            height: 100%;
            overflow: hidden;
            z-index: 1;
            pointer-events: none;
        }

        .particle {
            position: absolute;
            width: 2px;
            height: 2px;
            background: #00f2ff;
            border-radius: 50%;
            opacity: 0;
            animation: floatParticle 8s ease-in-out infinite;
        }

        @keyframes floatParticle {
            0% {
                opacity: 0;
                transform: translateY(100vh) translateX(0);
            }
            10% { opacity: 0.8; }
            90% { opacity: 0.5; }
            100% {
                opacity: 0;
                transform: translateY(-20vh) translateX(50px);
            }
        }

        /* الحاوية الرئيسية - تصميم فاخر */
        .neo-container {
            width: 1400px;
            height: 850px;
            position: relative;
            z-index: 10;
            perspective: 1200px;
        }

        .glass-panel {
            width: 100%;
            height: 100%;
            background: rgba(6, 10, 20, 0.55);
            backdrop-filter: blur(20px);
            border-radius: 56px;
            border: 1px solid rgba(0, 242, 255, 0.3);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255, 46, 99, 0.2), 0 0 60px rgba(0, 242, 255, 0.15);
            display: flex;
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
        }

        /* سايد بار متطور */
        .vault-sidebar {
            width: 380px;
            background: linear-gradient(165deg, rgba(0, 5, 15, 0.95), rgba(10, 15, 30, 0.9));
            backdrop-filter: blur(16px);
            border-left: 1px solid rgba(0, 242, 255, 0.5);
            padding: 40px 28px;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow-y: auto;
        }

        .vault-sidebar::-webkit-scrollbar {
            width: 4px;
        }

        .vault-sidebar::-webkit-scrollbar-track {
            background: rgba(255,255,255,0.05);
            border-radius: 4px;
        }

        .vault-sidebar::-webkit-scrollbar-thumb {
            background: #ff2e63;
            border-radius: 4px;
        }

        .glow-logo {
            text-align: center;
            margin-bottom: 40px;
        }

        .glow-logo h1 {
            font-family: 'Orbitron', monospace;
            font-size: 2.8rem;
            font-weight: 900;
            background: linear-gradient(135deg, #ffffff 0%, #00f2ff 50%, #ff2e63 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            letter-spacing: 5px;
            text-shadow: 0 0 20px rgba(0,242,255,0.3);
        }

        .glow-logo p {
            color: #6c7a9e;
            font-size: 0.8rem;
            margin-top: 12px;
            font-family: 'Share Tech Mono', monospace;
        }

        .stats-card {
            background: rgba(0, 242, 255, 0.03);
            border: 1px solid rgba(0, 242, 255, 0.2);
            border-radius: 24px;
            padding: 20px;
            margin: 20px 0;
        }

        .stat-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 15px;
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.8rem;
            color: #aab3cf;
        }

        .stat-value {
            color: #00f2ff;
            font-weight: bold;
        }

        .agent-profile {
            background: linear-gradient(135deg, rgba(255,46,99,0.12), rgba(0,242,255,0.08));
            border-radius: 28px;
            padding: 28px 24px;
            border: 1px solid rgba(255,255,255,0.1);
            margin-top: auto;
            text-align: center;
        }

        .agent-avatar {
            width: 70px;
            height: 70px;
            margin: 0 auto 15px;
            background: linear-gradient(135deg, #ff2e63, #00f2ff);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            box-shadow: 0 0 20px rgba(0,242,255,0.5);
        }

        /* المنطقة الرئيسية */
        .core-area {
            flex: 1;
            padding: 45px 50px;
            display: flex;
            flex-direction: column;
        }

        .status-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 35px;
            padding-bottom: 20px;
            border-bottom: 2px solid rgba(0, 242, 255, 0.2);
        }

        .title-section h2 {
            color: white;
            font-size: 1.9rem;
            font-weight: 700;
        }

        .title-section span {
            color: #00f2ff;
            font-family: 'Share Tech Mono';
        }

        .live-badge {
            background: rgba(0, 255, 136, 0.15);
            border: 1px solid #00ff88;
            border-radius: 50px;
            padding: 8px 20px;
            color: #00ff88;
            font-family: 'Share Tech Mono';
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .pulse-ring {
            width: 10px;
            height: 10px;
            background: #00ff88;
            border-radius: 50%;
            box-shadow: 0 0 10px #00ff88;
            animation: pulse-ring 1.5s infinite;
        }

        @keyframes pulse-ring {
            0% { box-shadow: 0 0 0 0 rgba(0, 255, 136, 0.7); }
            100% { box-shadow: 0 0 0 10px rgba(0, 255, 136, 0); }
        }

        /* بطاقة السؤال */
        .question-card {
            background: rgba(0, 0, 0, 0.6);
            border-radius: 32px;
            padding: 35px;
            margin-bottom: 25px;
            border-right: 5px solid #ff2e63;
            transition: all 0.3s;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        }

        .question-card:hover {
            border-right-color: #00f2ff;
            transform: translateX(-5px);
        }

        .q-marker {
            color: #ff2e63;
            font-family: 'Share Tech Mono';
            font-size: 0.75rem;
            margin-bottom: 15px;
            letter-spacing: 2px;
        }

        #currentQuestion {
            color: #fff;
            font-size: 1.7rem;
            font-weight: 600;
            line-height: 1.5;
            text-shadow: 0 1px 3px rgba(0,0,0,0.5);
        }

        /* حقل الرد المطور */
        .response-field {
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(0, 242, 255, 0.3);
            border-radius: 28px;
            padding: 22px;
            width: 100%;
            color: #00f2ff;
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.95rem;
            resize: none;
            outline: none;
            transition: 0.2s;
        }

        .response-field:focus {
            border-color: #00f2ff;
            box-shadow: 0 0 25px rgba(0,242,255,0.2);
            background: rgba(0,0,0,0.7);
        }

        /* أزرار أنيقة */
        .button-fleet {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin-top: 35px;
        }

        .cyber-btn {
            padding: 18px 24px;
            border-radius: 40px;
            border: none;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.25s ease;
            font-family: 'Cairo', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }

        .cyber-btn-primary {
            background: linear-gradient(95deg, #00f2ff, #0066ff);
            color: #000;
            box-shadow: 0 4px 15px rgba(0,242,255,0.3);
        }

        .cyber-btn-secondary {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.2);
            color: white;
        }

        .cyber-btn-success {
            background: linear-gradient(95deg, #00ff88, #00cc66);
            color: #000;
            grid-column: span 2;
            font-family: 'Orbitron', monospace;
            font-weight: 800;
            letter-spacing: 2px;
        }

        .cyber-btn:hover {
            transform: translateY(-3px);
            filter: brightness(1.1);
            box-shadow: 0 8px 25px rgba(0,0,0,0.4);
        }

        .danger-mini {
            background: transparent;
            border: 1px solid #ff2e63;
            color: #ff2e63;
            padding: 8px 16px;
            border-radius: 30px;
            cursor: pointer;
            transition: 0.2s;
            font-weight: bold;
        }

        .danger-mini:hover {
            background: #ff2e63;
            color: white;
        }

        /* Overlay فاخر */
        .premium-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.98);
            backdrop-filter: blur(35px);
            z-index: 200;
            display: none;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            border-radius: 56px;
            animation: slideGlow 0.5s ease;
        }

        @keyframes slideGlow {
            from {
                opacity: 0;
                transform: scale(0.95);
                backdrop-filter: blur(0);
            }
            to {
                opacity: 1;
                transform: scale(1);
                backdrop-filter: blur(35px);
            }
        }

        .session-code-block {
            background: #000000aa;
            border: 2px solid #00ff88;
            border-radius: 70px;
            padding: 25px 60px;
            margin: 30px;
        }

        .session-code-block .code {
            font-family: 'Orbitron', monospace;
            font-size: 3.5rem;
            font-weight: 800;
            color: #00ff88;
            letter-spacing: 12px;
            text-shadow: 0 0 30px #00ff88;
        }


        
    </style>
</head>
<body>
<div class="cyber-bg"></div>
<div class="particles" id="particles"></div>

<div class="neo-container">
    <div class="glass-panel">
        <div class="vault-sidebar">
            <div class="glow-logo">
                <h1>BLACK CODE</h1>
                <p>INVESTIGATION FORENSIC v4.0</p>
            </div>

            <div class="stats-card">
                <div class="stat-row">
                    <span><i class="fas fa-lock"></i> التشفير</span>
                    <span class="stat-value">AES-512 + QUANTUM</span>
                </div>
                <div class="stat-row">
                    <span><i class="fas fa-database"></i> قاعدة البيانات</span>
                    <span class="stat-value">Oracle Hyperion</span>
                </div>
                <div class="stat-row">
                    <span><i class="fas fa-fingerprint"></i> نمط التحقيق</span>
                    <span class="stat-value">Dark Web Forensics</span>
                </div>
                <div class="stat-row">
                    <span><i class="fas fa-shield-alt"></i> الحماية</span>
                    <span class="stat-value">Zero-Trust Network</span>
                </div>
            </div>

            <div class="agent-profile">
                <div class="agent-avatar">
                    <i class="fas fa-user-secret"></i>
                </div>
                <div style="font-size: 1.4rem; font-weight: bold; color: white; margin: 10px 0 5px;">MOHAMED_ALI</div>
                <div style="color: #00f2ff; font-size: 0.75rem; font-family: monospace;">INV-ID: 9F3A-77BC-22D</div>
                <div style="margin-top: 15px; padding-top: 10px; border-top: 1px solid rgba(255,255,255,0.1); font-size: 0.7rem; color: #ff2e63;">
                    <i class="fas fa-certificate"></i> صلاحية المستوى السادس
                </div>
            </div>
        </div>

        <div class="core-area">
            <div class="status-header">
                <div class="title-section">
                    <h2>محرك <span>البروتوكولات</span> الجنائية</h2>
                    <p style="color:#8a99c4; margin-top: 5px;">إنشاء أسئلة تحقيق ديناميكية | ربط آمن فوري</p>
                </div>
                <div class="live-badge">
                    <div class="pulse-ring"></div>
                    ENCRYPTION ACTIVE
                </div>
            </div>

            <div class="question-card">
                <div class="q-marker">
                    <i class="fas fa-skull"></i> QUESTION POOL | الوضع المظلم
                </div>
                <div id="currentQuestion">⚡ انتظر إضافة أسئلة التحقيق ... <br><span style="font-size: 0.9rem; color:#7a85a5;">اضغط على زر الإضافة لبدء بناء سيناريو الجلسة</span></div>
            </div>

            <textarea class="response-field" id="responsePreview" rows="4" readonly placeholder="[ نظام التشفير المسبق ] … سيتم ربط ردود المحقق تلقائياً مع كود الجلسة عند الإنهاء."></textarea>

            <div class="button-fleet">
                <button class="cyber-btn cyber-btn-primary" id="addQuestionBtn">
                    <i class="fas fa-plus-circle"></i> إضافة سؤال جنائي
                </button>
                <button class="cyber-btn cyber-btn-secondary" id="nextBtn">
                    <i class="fas fa-eye"></i> تصفح الأسئلة
                </button>
                <button class="cyber-btn cyber-btn-success" id="generateCodeBtn">
                    <i class="fas fa-key"></i> إنهاء & توليد كود الجلسة
                </button>
            </div>
            <div style="display: flex; justify-content: flex-end; margin-top: 20px;">
                <button id="clearQuestionsBtn" class="danger-mini">
                    <i class="fas fa-trash-alt"></i> مسح جميع الأسئلة
                </button>
            </div>
        </div>

        <div id="sessionOverlay" class="premium-overlay">
            <i class="fas fa-check-circle" style="font-size: 4rem; color: #00ff88; margin-bottom: 20px;"></i>
            <h2 style="color: white; font-size: 2.2rem;">تم تسجيل البروتوكول</h2>
            <p style="color: #aaa; margin-bottom: 15px;">كود جلسة التحقيق الموحد (استخدمه للوصول إلى الأسئلة)</p>
            <div class="session-code-block">
                <div id="finalCodeDisplay" class="code">BC-0000</div>
            </div>
            <div id="questionsPreviewList" style="max-width: 550px; background: rgba(0,0,0,0.7); border-radius: 28px; padding: 20px; margin: 15px; font-family: monospace; color: #aaffdd; text-align: right;"></div>
            <button id="newSessionBtn" class="cyber-btn cyber-btn-primary" style="padding: 14px 40px; margin-top: 15px;">
                <i class="fas fa-sync-alt"></i> بدء جلسة جديدة
            </button>
        </div>
    </div>
</div>

<script>
    // --------------------- النظام المتقدم -------------------------
    let questions = [];          
    let currentIdx = 0;

    const currentQDiv = document.getElementById('currentQuestion');
    const responsePreview = document.getElementById('responsePreview');
    const addBtn = document.getElementById('addQuestionBtn');
    const nextBtn = document.getElementById('nextBtn');
    const generateBtn = document.getElementById('generateCodeBtn');
    const clearBtn = document.getElementById('clearQuestionsBtn');
    const sessionOverlay = document.getElementById('sessionOverlay');
    const finalCodeSpan = document.getElementById('finalCodeDisplay');
    const questionsPreviewDiv = document.getElementById('questionsPreviewList');
    const newSessionBtn = document.getElementById('newSessionBtn');

    function refreshUI() {
        const total = questions.length;
        if (total === 0) {
            currentQDiv.innerHTML = '⚠️ لا توجد أسئلة حتى الآن. <span style="font-size: 1rem;">ابدأ بإضافة سؤال تحقيق.</span>';
            responsePreview.value = '⛔ لم يتم تسجيل أي سؤال بعد.';
            return;
        }
        if (currentIdx >= total) currentIdx = total - 1;
        const qText = questions[currentIdx];
        currentQDiv.innerHTML = `<i class="fas fa-question-circle" style="color:#00f2ff;"></i> \${qText}`;
        responsePreview.value = `📌 [ مسودة الرد على السؤال \${currentIdx+1} ]\n└─ السؤال: "\${qText}"\n└─ التوقيع: \${new Date().toLocaleTimeString()}`;
    }

    function updateSidebarStat() {
        const statCard = document.querySelector('.stats-card');
        let existing = document.getElementById('dynamicQCount');
        if (!existing) {
            const newStat = document.createElement('div');
            newStat.className = 'stat-row';
            newStat.id = 'dynamicQCount';
            newStat.innerHTML = `<span><i class="fas fa-list"></i> الأسئلة المسجلة</span><span class="stat-value" id="qCountValue">0</span>`;
            statCard.appendChild(newStat);
        }
        document.getElementById('qCountValue').innerText = questions.length;
    }

    function addInvestigationQuestion() {
        const pass = prompt("🔐 صلاحية المستوى السادس – أدخل كلمة المرور:", "");
        if (pass === "mohamed") {
            const newQ = prompt("✍️ أكتب سؤال التحقيق الجنائي:", "");
            if (newQ && newQ.trim() !== "") {
                questions.push(newQ.trim());
                currentIdx = questions.length - 1;
                refreshUI();
                updateSidebarStat();
                showFloatingMessage("✓ تم إضافة السؤال بنجاح", "#00ff88");
            }
        } else {
            alert("❌ كلمة المرور غير صحيحة.");
        }
    }

    function browseQuestions() {
        if (questions.length === 0) return alert("⚠️ لا توجد أسئلة.");
        currentIdx = (currentIdx + 1) % questions.length;
        refreshUI();
    }

    function eraseAllQuestions() {
        if (confirm("⚠️ هل تريد حذف جميع الأسئلة؟")) {
            questions = [];
            currentIdx = 0;
            refreshUI();
            updateSidebarStat();
        }
    }

    // الدالة دي اللي كان فيها اللغبطة.. تم الإصلاح:
    function generateSession() {
        if (questions.length === 0) {
            alert("❌ لا يمكن إنهاء الجلسة بدون أسئلة.");
            return;
        }

        const timestamp = Date.now().toString(36).toUpperCase();
        const random = Math.floor(10000 + Math.random() * 90000);
        const sessionKey = `BC-\${random}-\${timestamp.slice(-4)}`;
        
        finalCodeSpan.innerText = sessionKey;

        // إرسال لـ Oracle
        questions.forEach((qText) => {
            saveToOracle(sessionKey, qText);
        });

        // عرض المعاينة في الـ Overlay
        let listHtml = `<strong style="color:#00f2ff;">📜 الأسئلة المسجلة (\${questions.length})</strong><br><br>`;
        questions.forEach((q, idx) => {
            listHtml += `<span style="color:#ff2e63;">\${idx+1}.</span> \${q.substring(0, 100)}<br>`;
        });
        
        questionsPreviewDiv.innerHTML = listHtml;
        sessionOverlay.style.display = "flex";
        showFloatingMessage("🔐 تم الحفظ في Oracle بنجاح", "#00ff88");
    }

    function saveToOracle(sessionCode, questionText) {
        const url = `SaveInvestigationServlet?code=\${sessionCode}&question=\${encodeURIComponent(questionText)}`;
        fetch(url)
            .then(res => res.text())
            .then(data => console.log("DB Sync:", data))
            .catch(err => console.error("DB Error:", err));
    }

    function resetSession() {
        sessionOverlay.style.display = "none";
        questions = [];
        currentIdx = 0;
        refreshUI();
        updateSidebarStat();
    }

    function showFloatingMessage(msg, color) {
        const toast = document.createElement("div");
        toast.innerText = msg;
        toast.className = "floating-toast"; // يفضل تضيف لها CSS بسيط
        Object.assign(toast.style, {
            position: "fixed", bottom: "30px", left: "50%", transform: "translateX(-50%)",
            background: "#0a0e1ab3", border: `1px solid \${color}`, color: color,
            padding: "12px 28px", borderRadius: "50px", zIndex: "9999"
        });
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 2500);
    }

    function createParticles() {
        const container = document.getElementById('particles');
        for (let i = 0; i < 50; i++) {
            const p = document.createElement('div');
            p.className = 'particle';
            p.style.left = `\${Math.random() * 100}%`;
            p.style.animationDelay = `\${Math.random() * 10}s`;
            container.appendChild(p);
        }
    }

    // الربط مع الأزرار
    addBtn.onclick = addInvestigationQuestion;
    nextBtn.onclick = browseQuestions;
    generateBtn.onclick = generateSession;
    clearBtn.onclick = eraseAllQuestions;
    newSessionBtn.onclick = resetSession;

    // تشغيل أولي
    createParticles();
    refreshUI();
</script>
</body>
</html>