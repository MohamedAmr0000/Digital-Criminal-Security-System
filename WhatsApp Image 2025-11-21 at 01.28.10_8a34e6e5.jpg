<%@page import="com.security.auth.InvestigationDAO"%>
<%@page import="java.util.List"%>
<%@page contentType="text/html" pageEncoding="UTF-8"%>
<%@page import="javax.servlet.http.HttpSession"%>

<%
    // 1. حماية الصفحة: التأكد من تسجيل الدخول
    if (session.getAttribute("username") == null) {
        response.sendRedirect("login.html");
        return;
    }
    
    // 2. جلب البيانات الحقيقية من السيسشن
    String username = (String) session.getAttribute("username");
    Object invIdObj = session.getAttribute("investigator_id");
    String invId = (invIdObj != null) ? invIdObj.toString() : "000";
%>
<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Investigator Profile | <%= username %></title>

<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;500;600;700&family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">

<style>
    /* الإعدادات الأساسية للتصميم الـ Cyber */
    *{ margin:0; padding:0; box-sizing:border-box; }
    :root{
        --red: #e01111; --red-bright: #ff2a2a; --bg: #050505;
        --card-glass: rgba(15, 15, 15, 0.75); --border-glass: rgba(224, 17, 17, 0.25);
        --text: #d4d4d4; --mono: 'Share Tech Mono', monospace;
        --head: 'Orbitron', sans-serif; --body: 'Rajdhani', sans-serif;
    }
    body{ background: var(--bg); color: var(--text); font-family: var(--body); overflow-x: hidden; min-height: 100vh; }

    /* خلفية الهكر */
    .dynamic-bg{ position: fixed; inset: 0; background-size: cover; background-position: center; filter: blur(5px) brightness(0.2); opacity: 0; transition: 0.4s; z-index: -2; }
    .dynamic-bg.active { opacity: 1; filter: blur(1px) brightness(0.5); }
    .scanlines{ position: fixed; inset: 0; pointer-events: none; z-index: 10; background: repeating-linear-gradient(to bottom, transparent 0px, transparent 2px, rgba(0,0,0,0.1) 3px, rgba(0,0,0,0.1) 4px); }

    .profile-wrapper{ padding: 40px; position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; }
    .top-bar{ display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
    .back-btn{ padding: 10px 20px; border: 1px solid var(--red); background: rgba(224, 17, 17, 0.1); color: var(--red-bright); border-radius: 4px; cursor: pointer; font-family: var(--head); font-size: 11px; }

    /* الرأس - الهيدر */
    .profile-header{ background: var(--card-glass); backdrop-filter: blur(15px); border: 1px solid var(--border-glass); border-radius: 15px; padding: 40px; display: flex; align-items: center; gap: 40px; margin-bottom: 30px; position: relative; overflow: hidden; }
    .profile-header::after { content: ""; position: absolute; top: -100%; left: 0; width: 100%; height: 100%; background: linear-gradient(to bottom, transparent, rgba(224, 17, 17, 0.15), transparent); animation: scan 5s linear infinite; }
    @keyframes scan { 0% { top: -100%; } 100% { top: 100%; } }

    .profile-img{ width: 160px; height: 160px; border-radius: 50%; border: 3px solid var(--red); background: var(--bg); animation: pulse-red 2.5s infinite; cursor: pointer; }
    @keyframes pulse-red { 0% { box-shadow: 0 0 0 0 rgba(224, 17, 17, 0.7); } 70% { box-shadow: 0 0 0 15px rgba(224, 17, 17, 0); } 100% { box-shadow: 0 0 0 0 rgba(224, 17, 17, 0); } }
    .profile-img img{ width: 100%; height: 100%; border-radius: 50%; object-fit: cover; }

    .grid{ display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 25px; }
    .card{ background: var(--card-glass); backdrop-filter: blur(10px); border: 1px solid var(--border-glass); padding: 25px; border-radius: 12px; }
    .card-title{ font-family: var(--head); font-size: 13px; color: var(--red-bright); margin-bottom: 20px; border-left: 3px solid var(--red); padding-left: 10px; }
    .info-list .info-item { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .stat-box{ background: rgba(255, 255, 255, 0.03); border: 1px solid var(--border-glass); padding: 20px; border-radius: 8px; text-align: center; }
    .stat-number{ font-family: var(--head); font-size: 32px; color: var(--red-bright); }
</style>
</head>
<body>
</style>
</head>
<body>

<div class="dynamic-bg" id="hackerBg"></div>
<div class="scanlines"></div>

<div class="profile-wrapper">
    <div class="top-bar">
        <button class="back-btn" onclick="location.href='logout.jsp'">← LOGOUT_SESSION</button>
        <div style="color:var(--red-bright); font-family:var(--mono);" id="clock"></div>
    </div>

    <header class="profile-header">
        <div class="profile-img" id="profileImageContainer">
            <img src="image/me.jpg" alt="Agent">
        </div>
        <div class="profile-info">
            <h1 class="profile-name"><%= username.toUpperCase() %></h1>
            <div style="color: var(--red-bright); font-family: var(--mono);">
                STATUS: <span style="color: #00ff66;">ACTIVE_NODE_<%= invId %></span>
            </div>
        </div>
    </header>

    <div class="grid">
        <div class="card-column">
            <div class="card">
                <div class="card-title">ACCOUNT_METADATA</div>
                <div class="info-list">
                    <div class="info-item">
                        <span class="info-label">INVESTIGATOR_ID</span>
                        <span class="info-value">#<%= invId %></span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">USER_TOKEN</span>
                        <span class="info-value">SECURE_LEVEL_5</span>
                    </div>
                </div>

                <div class="nav" style="margin-top: 20px; display: flex; flex-direction: column; gap: 10px;">
                    <a href="DashBord.jsp" style="text-decoration: none; display: block;">
                        <div class="nav-item" style="padding: 12px; border: 1px solid var(--border-glass); background: rgba(224,17,17,0.05); color: var(--text); border-radius: 8px; cursor: pointer; transition: 0.3s;">
                            <span class="icon" style="margin-right: 10px; color: var(--red-bright);">⊞</span> Dashboard
                        </div>
                    </a>
                </div>
            </div>

            <div class="card" style="margin-top: 25px;">
                <div class="card-title">SESSION_ARCHIVE</div>
                <div class="session-list" style="max-height: 200px; overflow-y: auto; font-family: var(--mono); font-size: 13px;">
                    <%
                        try {
                            InvestigationDAO dao = new InvestigationDAO();
                            List<String> mySessions = dao.getMySessions(Integer.parseInt(invId));
                            if(mySessions == null || mySessions.isEmpty()){
                                out.println("<div style='color:#555; padding:10px;'>NO_ACTIVE_SESSIONS_FOUND</div>");
                            } else {
                                for(String code : mySessions) {
                    %>
                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid rgba(224,17,17,0.1);">
                            <span style="color: #eee;">> <%= code %></span>
                            <a href="view_questions.jsp?code=<%= code %>" style="color: var(--red-bright); text-decoration: none; font-size: 11px; border: 1px solid var(--red); padding: 2px 8px; border-radius: 4px;">
                                OPEN_DATA
                            </a>
                        </div>
                    <%      }
                            }
                        } catch(Exception e) {
                            out.println("Error loading sessions.");
                        }
                    %>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-title">LIVE_STATISTICS</div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                <div class="stat-box">
                    <div class="stat-number count" data-target="27">0</div>
                    <div style="font-size: 11px;">CASES</div>
                </div>
                <div class="stat-box">
                    <div class="stat-number"><span class="count" data-target="91">0</span>%</div>
                    <div style="font-size: 11px;">ACCURACY</div>
                </div>
            </div>
            
            <div style="margin-top: 20px; padding: 15px; background: rgba(0,255,136,0.03); border: 1px solid rgba(0,255,136,0.1); border-radius: 8px;">
                <div style="color: #00ff88; font-size: 10px; font-family: var(--mono); margin-bottom: 5px;">SYSTEM_INTEGRITY</div>
                <div style="height: 4px; background: #222; border-radius: 2px;">
                    <div style="width: 98%; height: 100%; background: #00ff88; box-shadow: 0 0 10px #00ff88;"></div>
                </div>
            </div>
        </div>
    </div> </div> <script>
// ... (كود الجافا سكريبت اللي كان في آخر ملفك زي ما هو) ...
</script>
<script>
// دالة العدادات
function runCounters() {
    const counters = document.querySelectorAll('.count');
    counters.forEach(counter => {
        const updateCount = () => {
            const target = +counter.getAttribute('data-target');
            const count = +counter.innerText;
            const inc = target / 100;
            if (count < target) {
                counter.innerText = Math.ceil(count + inc);
                setTimeout(updateCount, 50);
            } else { counter.innerText = target; }
        };
        updateCount();
    });
}
// الساعة وتأثير الهكر
function updateClock(){
    document.getElementById("clock").innerText = new Date().toLocaleTimeString();
}
setInterval(updateClock, 1000);
window.onload = runCounters;

const hackerBg = document.getElementById("hackerBg");
const profileContainer = document.getElementById("profileImageContainer");
hackerBg.style.backgroundImage = "url('https://images.pexels.com/photos/5380664/pexels-photo-5380664.jpeg')";

profileContainer.addEventListener("mouseenter", () => hackerBg.classList.add("active"));
profileContainer.addEventListener("mouseleave", () => hackerBg.classList.remove("active"));
</script>

</body>
</html>